<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <RelativeLayout
            android:id="@+id/rlRuleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_alignParentStart="true"
                android:layout_toLeftOf="@id/llBtnContainer"
                android:layout_marginRight="8dp">

                <ImageView
                    android:id="@+id/imageViewFwd"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginRight="8dp"
                    app:srcCompat="@drawable/arrow_forward" />

                <TextView
                    android:id="@+id/txtFwdRemainingLbl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:text="Forwards remaining"
                    android:textColor="@color/black_100"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBtnContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:clickable="true">
                <TextView
                    android:id="@+id/txtFwdRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:text="0"
                    android:textColor="@color/black_100"
                    android:textSize="18sp" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:paddingLeft="48dp"
            android:paddingRight="48dp"
            android:gravity="center"
            android:visibility="gone">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFwdPurchase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cornerRadius="45dp"
                style="@style/Widget.MaterialComponents.Button"
                android:text="Purchase Forwards" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>